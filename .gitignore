# ============================================================
# IoT Smart Parking System — .gitignore
# ESP32 / Arduino + Huawei Cloud IoTDA
# ============================================================


# ── Credentials & Secrets ────────────────────────────────────
# NEVER commit real WiFi passwords or cloud keys
secrets.h
credentials.h
config.h
*.env
.env
.env.local


# ── Arduino IDE ──────────────────────────────────────────────
# Build output folders generated by Arduino IDE
build/
*.elf
*.bin
*.hex
*.map

# Arduino IDE cache
.arduino15/
arduino-cli.yaml


# ── PlatformIO (if migrated later) ───────────────────────────
.pio/
.pioenvs/
.piolibdeps/
.vscode/
*.pioenvs

# PlatformIO local config (contains your personal paths)
platformio.ini.local


# ── VS Code ──────────────────────────────────────────────────
.vscode/
*.code-workspace


# ── macOS ────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes


# ── Windows ──────────────────────────────────────────────────
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk


# ── Linux ────────────────────────────────────────────────────
*~
.fuse_hidden*
.directory
.Trash-*


# ── Logs & Debug output ───────────────────────────────────────
*.log
logs/
serial_output.txt


# ── Node / npm (if you add a web tools later) ────────────────
node_modules/
npm-debug.log*
package-lock.json


# ── Python (if you add scripts later) ────────────────────────
__pycache__/
*.py[cod]
*.pyo
venv/
.venv/


# ── Fritzing ─────────────────────────────────────────────────
# Keep .fzz source but ignore auto-generated exports
*.fzpz
*_breadboard.svg
*_schematic.svg
*_pcb.svg


# ── Miscellaneous ─────────────────────────────────────────────
*.tmp
*.bak
*.swp
*.orig
*.ino.bak
